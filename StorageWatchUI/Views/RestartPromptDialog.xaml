<Window x:Class="StorageWatchUI.Views.RestartPromptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Restart StorageWatch"
        Width="460"
        Height="260"
        MinWidth="420"
        MinHeight="240"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BackgroundColor}"
        WindowStyle="ToolWindow"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Grid Margin="20">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="Update installed"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="{DynamicResource PrimaryText}"
                       TextAlignment="Center"
                       Margin="0,0,0,12"/>

            <TextBlock Text="Restart StorageWatch now to finish applying this update."
                       FontSize="13"
                       Foreground="{DynamicResource SecondaryText}"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="12,0,12,24"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="Restart later"
                        Width="130"
                        Margin="0,0,10,0"
                        Background="Transparent"
                        Foreground="{DynamicResource PrimaryText}"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource BorderBrush}"
                        Click="RestartLaterButton_Click"/>
                <Button Content="Restart now"
                        Width="130"
                        Click="RestartNowButton_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
