<UserControl x:Class="StorageWatchUI.Views.UpdateBanner"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Height="72"
             Background="{DynamicResource CardBackground}">
    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="12,8">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="Update available for StorageWatch"
                           Foreground="{DynamicResource PrimaryText}"
                           FontSize="14"
                           FontWeight="SemiBold"/>
                <TextBlock Margin="0,4,0,0"
                           Foreground="{DynamicResource SecondaryText}"
                           FontSize="12">
                    <Run Text="Current: "/>
                    <Run Text="{Binding CurrentVersion}"/>
                    <Run Text="   •   Available: "/>
                    <Run Text="{Binding LatestVersion}"/>
                </TextBlock>
            </StackPanel>

            <Button Grid.Column="1"
                    Content="Install update"
                    Command="{Binding BeginUpdateCommand}"
                    Margin="12,0,8,0"
                    MinWidth="120"
                    VerticalAlignment="Center"/>

            <Button Grid.Column="2"
                    Content="Later"
                    Command="{Binding RemindMeLaterCommand}"
                    Margin="0"
                    MinWidth="90"
                    VerticalAlignment="Center"
                    Background="Transparent"
                    Foreground="{DynamicResource PrimaryText}"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource BorderBrush}"/>
        </Grid>
    </Border>
</UserControl>
