<Window x:Class="StorageWatchUI.Views.UpdateProgressDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Installing Update" Height="260" Width="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BackgroundColor}"
        WindowStyle="ToolWindow">
    <Grid Margin="20">
        <StackPanel VerticalAlignment="Center">
            <!-- Title -->
            <TextBlock Text="Installing StorageWatch update"
                       FontSize="16"
                       FontWeight="Bold"
                       Foreground="{DynamicResource PrimaryText}"
                       Margin="0,0,0,14"/>

            <!-- Status Text -->
            <TextBlock Text="{Binding StatusText}"
                       FontSize="13"
                       Foreground="{DynamicResource SecondaryText}"
                       Margin="0,0,0,12"/>

            <!-- Progress Bar -->
            <ProgressBar Height="22"
                         Value="{Binding Progress}"
                         IsIndeterminate="{Binding IsIndeterminate}"
                         Margin="0,0,0,10"/>

            <!-- Progress Percentage (when determinate) -->
            <TextBlock Text="{Binding Progress, StringFormat=Progress: {0:N0}%}"
                       Foreground="{DynamicResource SecondaryText}"
                       FontSize="11"
                       TextAlignment="Center"
                       Margin="0,0,0,18"/>

            <!-- Cancel Button -->
            <Button Content="Cancel"
                    Command="{Binding CancelCommand}"
                    Width="100"
                    HorizontalAlignment="Center"
                    Background="Transparent"
                    Foreground="{DynamicResource PrimaryText}"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource BorderBrush}"/>
        </StackPanel>
    </Grid>
</Window>
